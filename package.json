    "ffmpeg-static": "^5.3.0",
    "lucide-react": "^1.14.0",
    "next": "16.2.6",
    "prisma": "^6.19.3",
    "react": "19.2.4",
    "react-day-picker": "^10.0.0",
    "react-dom": "19.2.4",
