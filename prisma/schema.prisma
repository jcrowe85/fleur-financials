// Fleur sales dashboard — Phase 1 schema.
// Raw landing tables mirror what each source returns; fact tables are the
// channel-agnostic shape the dashboard reads from.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────
// RAW LANDING TABLES
// ─────────────────────────────────────────────

model RawAmazonSalesDaily {
  id                 String   @id @default(cuid())
  date               DateTime @db.Date
  accountId          String
  marketplace        String
  orderedSalesAmount Decimal  @db.Decimal(12, 2)
  shippedSalesAmount Decimal  @db.Decimal(12, 2)
  unitsOrdered       Int
  unitsShipped       Int
  totalOrderItems    Int
  currency           String   @default("USD")
  syncedAt           DateTime @default(now())

  @@unique([date, accountId])
  @@index([date])
  @@index([marketplace])
}

model RawShopifyOrdersDaily {
  id         String   @id @default(cuid())
  date       DateTime @db.Date
  shopDomain String
  grossSales Decimal  @db.Decimal(12, 2)
  netSales   Decimal  @db.Decimal(12, 2)
  discounts  Decimal  @db.Decimal(12, 2) @default(0)
  cogs       Decimal? @db.Decimal(12, 2)
  orderCount Int
  unitsSold  Int
  currency   String   @default("USD")
  syncedAt   DateTime @default(now())

  @@unique([date, shopDomain])
  @@index([date])
}

model RawTiktokAdsDaily {
  id              String   @id @default(cuid())
  date            DateTime @db.Date
  accountId       String
  campaignId      String?
  spend           Decimal  @db.Decimal(12, 2)
  impressions     Int
  clicks          Int
  conversions     Int
  conversionValue Decimal  @db.Decimal(12, 2)
  currency        String   @default("USD")
  syncedAt        DateTime @default(now())

  @@unique([date, accountId, campaignId])
  @@index([date])
}

// ─────────────────────────────────────────────
// FACT TABLES (dashboard reads from these)
// ─────────────────────────────────────────────

model FactSalesDaily {
  id         String   @id @default(cuid())
  date       DateTime @db.Date
  channel    String
  subChannel String
  grossSales Decimal  @db.Decimal(12, 2)
  netSales   Decimal  @db.Decimal(12, 2)
  cogs       Decimal? @db.Decimal(12, 2)
  discounts  Decimal? @db.Decimal(12, 2)
  units      Int
  orders     Int
  currency   String   @default("USD")
  updatedAt  DateTime @updatedAt

  @@unique([date, channel, subChannel])
  @@index([date])
  @@index([channel])
}

model FactAdSpendDaily {
  id                 String   @id @default(cuid())
  date               DateTime @db.Date
  channel            String
  spend              Decimal  @db.Decimal(12, 2)
  impressions        Int
  clicks             Int
  conversions        Int
  attributedRevenue  Decimal  @db.Decimal(12, 2)
  currency           String   @default("USD")
  updatedAt          DateTime @updatedAt

  @@unique([date, channel])
  @@index([date])
}

// ─────────────────────────────────────────────
// SYNC LOG
// ─────────────────────────────────────────────

model SyncLog {
  id              String    @id @default(cuid())
  source          String
  startedAt       DateTime  @default(now())
  finishedAt      DateTime?
  status          String
  recordsUpserted Int       @default(0)
  errorMessage    String?

  @@index([source, startedAt])
}
