// Fleur sales dashboard — Phase 1 schema.
// Raw landing tables mirror what each source returns; fact tables are the
// channel-agnostic shape the dashboard reads from.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────
// RAW LANDING TABLES
// ─────────────────────────────────────────────

model RawAmazonSalesDaily {
  id                 String   @id @default(cuid())
  date               DateTime @db.Date
  accountId          String
  marketplace        String
  orderedSalesAmount Decimal  @db.Decimal(12, 2)
  shippedSalesAmount Decimal  @db.Decimal(12, 2)
  unitsOrdered       Int
  unitsShipped       Int
  totalOrderItems    Int
  cogs               Decimal? @db.Decimal(12, 2)
  currency           String   @default("USD")
  syncedAt           DateTime @default(now())

  @@unique([date, accountId])
  @@index([date])
  @@index([marketplace])
}

model RawShopifyOrdersDaily {
  id            String   @id @default(cuid())
  date          DateTime @db.Date
  shopDomain    String
  grossSales    Decimal  @db.Decimal(12, 2)
  netSales      Decimal  @db.Decimal(12, 2)
  discounts     Decimal  @db.Decimal(12, 2) @default(0)
  returnsAmount Decimal? @db.Decimal(12, 2)
  cogs          Decimal? @db.Decimal(12, 2)
  orderCount    Int
  unitsSold     Int
  currency      String   @default("USD")
  syncedAt      DateTime @default(now())

  @@unique([date, shopDomain])
  @@index([date])
}

model RawMetaAdsDaily {
  id          String   @id @default(cuid())
  date        DateTime @db.Date
  spend       Decimal  @db.Decimal(12, 2)
  impressions Int
  clicks      Int
  conversions Int
  revenue     Decimal  @db.Decimal(12, 2)
  currency    String   @default("USD")
  syncedAt    DateTime @default(now())

  @@unique([date])
  @@index([date])
}

model RawTiktokAdsDaily {
  id              String   @id @default(cuid())
  date            DateTime @db.Date
  accountId       String
  campaignId      String?
  spend           Decimal  @db.Decimal(12, 2)
  impressions     Int
  clicks          Int
  conversions     Int
  conversionValue Decimal  @db.Decimal(12, 2)
  currency        String   @default("USD")
  syncedAt        DateTime @default(now())

  @@unique([date, accountId, campaignId])
  @@index([date])
}

// ─────────────────────────────────────────────
// FACT TABLES (dashboard reads from these)
// ─────────────────────────────────────────────

model FactSalesDaily {
  id           String   @id @default(cuid())
  date         DateTime @db.Date
  channel      String
  subChannel   String
  grossSales    Decimal  @db.Decimal(12, 2)
  netSales      Decimal  @db.Decimal(12, 2)
  cogs          Decimal? @db.Decimal(12, 2)
  discounts     Decimal? @db.Decimal(12, 2)
  units         Int
  orders        Int
  refundCount   Int      @default(0)
  refundAmount  Decimal? @db.Decimal(12, 2)
  fbaFees       Decimal? @db.Decimal(12, 2)
  referralFees  Decimal? @db.Decimal(12, 2)
  currency      String   @default("USD")
  updatedAt     DateTime @updatedAt

  @@unique([date, channel, subChannel])
  @@index([date])
  @@index([channel])
}

// Hourly sales buckets for intraday "pace" comparisons (today-so-far vs the
// prior day through the same time of day). Only the sales channels are synced
// hourly (Shopify, Amazon); ad spend stays daily. Lean by design — no COGS or
// fee breakdown — since this drives a pace signal, not full P&L. Synced on a
// short rolling window (a few days), not full history.
model FactSalesHourly {
  id         String   @id @default(cuid())
  date       DateTime @db.Date
  hour       Int      // 0-23, bucketed in the business timezone
  channel    String
  subChannel String
  grossSales Decimal  @db.Decimal(12, 2)
  netSales   Decimal  @db.Decimal(12, 2)
  units      Int
  orders     Int
  currency   String   @default("USD")
  updatedAt  DateTime @updatedAt

  @@unique([date, hour, channel, subChannel])
  @@index([date, channel])
}

model FactAdSpendDaily {
  id                 String   @id @default(cuid())
  date               DateTime @db.Date
  channel            String
  spend              Decimal  @db.Decimal(12, 2)
  impressions        Int
  clicks             Int
  conversions        Int
  attributedRevenue  Decimal  @db.Decimal(12, 2)
  currency           String   @default("USD")
  updatedAt          DateTime @updatedAt

  @@unique([date, channel])
  @@index([date])
}

// ─────────────────────────────────────────────
// META ADS HIERARCHY (agency-grade dashboard)
// ─────────────────────────────────────────────

// Dimension table: one row per campaign / ad set / ad. Holds the hierarchy
// links plus the *current* status & budget (overwritten on every sync). The
// id is Meta's own object id so insight rows join straight to it.
model MetaEntity {
  id               String   @id // Meta campaign/adset/ad id
  level            String   // "campaign" | "adset" | "ad"
  name             String
  campaignId       String?  // parent campaign (null for campaign rows)
  adsetId          String?  // parent ad set (null for campaign/adset rows)
  status           String?  // configured status (ACTIVE / PAUSED …)
  effectiveStatus  String?  // delivery status incl. parent/limit reasons
  objective        String?  // campaign objective (campaign rows only)
  dailyBudget      Decimal? @db.Decimal(12, 2)
  lifetimeBudget   Decimal? @db.Decimal(12, 2)
  creativeThumbUrl String?  // ad-level creative thumbnail
  syncedAt         DateTime @default(now())

  @@index([level])
  @@index([campaignId])
  @@index([adsetId])
}

// Fact table: one row per (date, level, entity). `level` includes "account"
// with the sentinel entityId "account" so the account rollup, the existing
// ad-cost pipeline, and the drill-down all read from one source.
model MetaInsightDaily {
  id               String   @id @default(cuid())
  date             DateTime @db.Date
  level            String   // "account" | "campaign" | "adset" | "ad"
  entityId         String   // Meta object id, or "account"
  spend            Decimal  @db.Decimal(12, 2)
  impressions      Int
  reach            Int      // non-additive across days; see meta-metrics.ts
  clicks           Int
  inlineLinkClicks Int
  outboundClicks   Int
  purchases        Int
  purchaseValue    Decimal  @db.Decimal(12, 2)
  addToCart        Int
  initiateCheckout Int
  landingPageViews Int
  videoViews3s     Int      // 3-second video plays (hook rate numerator)
  thruplays        Int      // ThruPlays (hold rate numerator)
  videoP25         Int
  videoP50         Int
  videoP75         Int
  videoP100        Int
  currency         String   @default("USD")
  syncedAt         DateTime @default(now())

  @@unique([date, level, entityId])
  @@index([date, level])
  @@index([entityId])
}

// ─────────────────────────────────────────────
// SYNC LOG
// ─────────────────────────────────────────────

model SyncLog {
  id              String    @id @default(cuid())
  source          String
  startedAt       DateTime  @default(now())
  finishedAt      DateTime?
  status          String
  recordsUpserted Int       @default(0)
  errorMessage    String?

  @@index([source, startedAt])
}

// ─────────────────────────────────────────────
// GIFT ENGINE ALERTS
// Error/alert feed pushed from the fleur-gift-engine app (sweep crashes, missed
// gifts). Surfaced in the dashboard's notification bell + log.
// ─────────────────────────────────────────────

model GiftEngineAlert {
  id        String    @id @default(cuid())
  kind      String // sweep_crash | sweep_errors | gift_verify_miss | verify_crash
  message   String // human-readable summary (the alert's details)
  meta      Json? // raw alert payload
  source    String    @default("gift-engine")
  createdAt DateTime  @default(now()) // when the alert fired
  readAt    DateTime? // null = unread

  @@index([createdAt])
  @@index([readAt])
}
