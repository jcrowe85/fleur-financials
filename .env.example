# Windsor.ai REST API key (server-only, never expose to client)
WINDSOR_API_KEY=

# Supabase Postgres
# Pooled connection (Transaction mode, port 6543) — used by the Next.js runtime.
DATABASE_URL=
# Direct connection (port 5432) — used by Prisma migrations only.
DIRECT_URL=

# Supabase client SDK (browser/SSR safe)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Shared secret for /api/sync/* cron routes — sent as `Authorization: Bearer ${CRON_SECRET}`
CRON_SECRET=

# Shared secret the fleur-gift-engine uses to POST error alerts to /api/alerts
# (notification bell). Must match FINANCIALS_ALERT_SECRET in fleur-gift-engine.
GIFT_ALERT_SECRET=

# Business timezone for sales-day boundaries (default: America/Los_Angeles).
# Committed default lives in .env; only set here to override per-environment.
BUSINESS_TIMEZONE=

# Meta Marketing API — powers the Meta Ads dashboard + ad-cost pipeline.
# Long-lived access token (regenerate in Graph API Explorer when it expires)
# and the numeric ad account id (no `act_` prefix).
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=

# Meta dashboard targets — drive the flagged-insight rules (all optional).
# ROAS target (default 2), optional CPA ceiling, frequency cap (default 3),
# and the minimum spend before a campaign is flagged (default 50).
META_ROAS_TARGET=
META_CPA_TARGET=
META_FREQ_CAP=
META_INSIGHT_MIN_SPEND=
